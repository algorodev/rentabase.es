---
/**
 * Sección CTA para captar suscriptores vía Buttondown.
 */
---

<section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-verde via-verde to-texto/90 text-white p-8 md:p-12">
  <!-- Patrón decorativo -->
  <div class="absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <svg class="w-full h-full" viewBox="0 0 400 400">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="400" height="400" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative z-10 max-w-xl">
    <span class="inline-block px-3 py-1 bg-acento/20 text-acento rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
      Newsletter gratuita
    </span>
    <h2 class="font-display text-2xl md:text-3xl font-bold leading-snug mb-3">
      Recibe las mejores guías financieras en tu email
    </h2>
    <p class="text-white/70 leading-relaxed mb-6">
      Una vez por semana, sin spam. Artículos sobre inversión, ahorro y fiscalidad
      directamente en tu bandeja de entrada.
    </p>

    <form
      action="https://buttondown.com/api/emails/embed-subscribe/algorodev"
      method="post"
      target="_blank"
      data-nl-form
      class="flex flex-col sm:flex-row gap-3"
    >
      <input
        type="email"
        name="email"
        placeholder="tu@email.com"
        required
        class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-acento focus:ring-1 focus:ring-acento transition-colors"
        aria-label="Dirección de email"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-acento text-texto font-semibold rounded-lg hover:bg-acento/90 transition-all hover:shadow-lg hover:shadow-acento/25 shrink-0"
      >
        Suscribirme
      </button>
    </form>
    <p class="text-xs text-white/40 mt-3">Sin spam. Cancela cuando quieras.</p>
  </div>
</section>

<script>
  // Buttondown's embed endpoint requires Cloudflare Turnstile verification,
  // which blocks direct fetch() calls. Fire the event when the browser's own
  // HTML5 validation passes (valid email format) and the form submits normally
  // to the new tab — standard practice for third-party newsletter endpoints.
  document.querySelectorAll<HTMLFormElement>('form[data-nl-form]').forEach((form) => {
    form.addEventListener('submit', () => {
      if (form.checkValidity()) {
        window.gtag?.('event', 'newsletter_signup', { method: 'website_form' });
      }
    });
  });
</script>
