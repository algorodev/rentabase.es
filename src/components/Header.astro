---
/** Cabecera principal del sitio con efecto de sombra al hacer scroll */
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/blog/', label: 'Blog' },
  { href: '/noticias/', label: 'Noticias' },
  { href: '/calculadoras/', label: 'Calculadoras' },
  { href: '/sobre-nosotros/', label: 'Sobre nosotros' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="bg-white/80 backdrop-blur-md border-b border-texto/[0.06] sticky top-0 z-50 transition-shadow duration-300">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegación principal">
    <!-- Logo -->
    <a href="/" class="flex items-center group">
      <img src="/assets/rentabase-logo-black.svg" alt="RentaBase" class="h-7 group-hover:opacity-80 transition-opacity" />
    </a>

    <!-- Navegación desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'relative text-sm font-medium transition-colors hover:text-verde py-1',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-verde'
                : 'text-texto/65',
            ]}
          >
            {label}
            {(currentPath === href || (href !== '/' && currentPath.startsWith(href))) && (
              <span class="absolute -bottom-[1px] left-0 right-0 h-[2px] bg-verde rounded-full" />
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Botón menú móvil -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-texto/65 hover:text-verde transition-colors rounded-lg hover:bg-texto/5"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-texto/[0.06] bg-white/95 backdrop-blur-md">
    <ul class="px-4 py-4 space-y-1">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block text-sm font-medium py-2.5 px-3 rounded-lg transition-all',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-verde bg-verde/5'
                : 'text-texto/65 hover:text-verde hover:bg-texto/[0.03]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const header = document.getElementById('site-header');

  // Toggle menú móvil con animación del icono
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Sombra en el header al hacer scroll
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header.classList.add('shadow-sm');
      } else {
        header.classList.remove('shadow-sm');
      }
    }, { passive: true });
  }
</script>
