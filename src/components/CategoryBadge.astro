---
/** Badge de categoría con color diferenciado por tema */

interface Props {
  category: 'inversion' | 'ahorro' | 'cripto' | 'fiscalidad';
}

const { category } = Astro.props;

const categoryConfig: Record<string, { label: string; classes: string }> = {
  inversion: { label: 'Inversión', classes: 'bg-verde/10 text-verde' },
  ahorro: { label: 'Ahorro', classes: 'bg-blue-100 text-blue-700' },
  cripto: { label: 'Criptomonedas', classes: 'bg-orange-100 text-orange-700' },
  fiscalidad: { label: 'Fiscalidad', classes: 'bg-purple-100 text-purple-700' },
};

const config = categoryConfig[category];
---

<span class:list={['inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded-full', config.classes]}>
  {config.label}
</span>
