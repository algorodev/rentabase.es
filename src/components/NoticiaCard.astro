---
import type { CollectionEntry } from 'astro:content';

interface Props {
  noticia: CollectionEntry<'noticias'>;
}

const { noticia } = Astro.props;
const { title, description, pubDate, weekStart, weekEnd, image } = noticia.data;

const weekRange = `${weekStart.toLocaleDateString('es-ES', { day: 'numeric' })} - ${weekEnd.toLocaleDateString('es-ES', { day: 'numeric', month: 'long' })}`;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group relative h-full flex flex-col rounded-xl bg-white border border-texto/8 shadow-sm overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <!-- Visual superior -->
  <div class="aspect-[16/10] relative overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="relative w-full h-full bg-gradient-to-br from-texto via-texto/95 to-verde transition-transform duration-500 group-hover:scale-[1.03]">
        <div class="absolute -bottom-16 -right-16 w-56 h-56 rounded-full bg-acento/25 blur-3xl pointer-events-none" aria-hidden="true"></div>
        <div class="relative z-10 h-full flex flex-col justify-end p-5" aria-hidden="true">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-acento/70 mb-2">Resumen semanal</p>
          <p class="font-display font-bold text-white text-xl leading-[1.1] line-clamp-3">{title}</p>
        </div>
      </div>
    )}
    <!-- Badge flotante -->
    <div class="absolute top-4 left-4 z-10">
      <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded-full bg-acento/90 text-texto">
        Noticias
      </span>
    </div>
  </div>

  <!-- Contenido -->
  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-center gap-2 mb-3 text-xs text-texto/60">
      <span>Semana del {weekRange}</span>
      <span aria-hidden="true">&middot;</span>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>

    <h3 class="font-display text-lg font-bold leading-snug mb-2 line-clamp-2">
      <a
        href={"/noticias/" + noticia.slug + "/"}
        class="card-link group-hover:text-verde transition-colors after:absolute after:inset-0 after:content-['']"
      >
        {title}
      </a>
    </h3>

    <p class="text-sm text-texto/65 leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>

    <!-- Indicador de lectura -->
    <div class="mt-auto">
      <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-verde group-hover:gap-2.5 transition-all">
        Leer resumen
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</article>
