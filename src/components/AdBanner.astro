---
/**
 * Unidad de anuncio AdSense in-article.
 * Renderiza solo cuando se proporciona un `slot` (ID de unidad de AdSense).
 * Sin slot, no renderiza nada — los anuncios pueden seguir apareciendo
 * vía Auto Ads (configurable en el panel de AdSense).
 */

interface Props {
  position: 'after-intro' | 'end-of-article';
  slot?: string;
}

const { position, slot } = Astro.props;
const PUBLISHER_ID = 'ca-pub-8726052197962848';
---

{slot && (
  <aside class="my-10" aria-label="Publicidad" data-ad-position={position}>
    <ins
      class="adsbygoogle"
      style="display:block; text-align:center;"
      data-ad-layout="in-article"
      data-ad-format="fluid"
      data-ad-client={PUBLISHER_ID}
      data-ad-slot={slot}
    ></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </aside>
)}
