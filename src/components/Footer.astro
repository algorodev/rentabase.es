---
/** Pie de página del sitio */
const currentYear = new Date().getFullYear();
---

<footer class="bg-texto text-white/75 mt-20 relative overflow-hidden">
  <!-- Patrón decorativo sutil -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <svg class="w-full h-full" viewBox="0 0 400 400">
      <defs>
        <pattern id="footer-dots" width="30" height="30" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="0.8" fill="white" />
        </pattern>
      </defs>
      <rect width="400" height="400" fill="url(#footer-dots)" />
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-14 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Sobre el blog -->
      <div class="md:col-span-2">
        <div class="mb-4">
          <img src="/assets/rentabase-logo-white.svg" alt="RentaBase" class="h-7" />
        </div>
        <p class="text-sm leading-relaxed max-w-sm">
          Blog sobre inversión, ahorro, criptomonedas y fiscalidad en España. Información
          clara y práctica para tomar mejores decisiones financieras.
        </p>
        <div class="mt-5 flex items-center gap-3">
          <a
            href="/rss.xml"
            class="inline-flex items-center gap-2 text-xs font-medium text-white/80 hover:text-acento transition-colors"
            aria-label="Feed RSS"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20a2.18 2.18 0 01-2.18-2.18 2.18 2.18 0 012.18-2.18zM4 4.44A15.56 15.56 0 0119.56 20H17.5A13.5 13.5 0 004 6.5V4.44m0 5.66A9.9 9.9 0 0113.9 20h-2.06A7.84 7.84 0 004 12.16V10.1z" />
            </svg>
            RSS
          </a>
          <span class="text-white/20" aria-hidden="true">&middot;</span>
          <a
            href="mailto:hola@rentabase.es"
            class="inline-flex items-center gap-2 text-xs font-medium text-white/80 hover:text-acento transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            hola@rentabase.es
          </a>
        </div>
      </div>

      <!-- Navegación -->
      <div>
        <h3 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Navegación</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="hover:text-white hover:translate-x-1 transition-all inline-block">Inicio</a></li>
          <li><a href="/blog" class="hover:text-white hover:translate-x-1 transition-all inline-block">Blog</a></li>
          <li><a href="/calculadoras" class="hover:text-white hover:translate-x-1 transition-all inline-block">Calculadoras</a></li>
          <li><a href="/sobre-nosotros" class="hover:text-white hover:translate-x-1 transition-all inline-block">Sobre nosotros</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Legal</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/politica-de-privacidad" class="hover:text-white hover:translate-x-1 transition-all inline-block">Política de privacidad</a></li>
          <li><a href="/rss.xml" class="hover:text-white hover:translate-x-1 transition-all inline-block">Feed RSS</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm">
      <p>&copy; {currentYear} RentaBase. Todos los derechos reservados.</p>
      <p class="text-white/50 text-xs">
        La información publicada no constituye asesoramiento financiero profesional.
      </p>
    </div>
  </div>
</footer>
